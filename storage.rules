rules_version = '2';
// Storage-Pfade: organizations/{orgId}/{path}
// Nur Mitglieder der Org dürfen lesen/schreiben. Max. 20 MB pro Datei.
service firebase.storage {
  match /b/{bucket}/o {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOrgMember(orgId) {
      return isSignedIn()
        && firestore.exists(
             /databases/(default)/documents/organizations/$(orgId)/members/$(request.auth.uid)
           );
    }

    match /organizations/{orgId}/{allPaths=**} {
      allow read: if isOrgMember(orgId);
      allow write: if isOrgMember(orgId)
                   && (request.resource == null
                       || request.resource.size < 20 * 1024 * 1024);
    }

    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
